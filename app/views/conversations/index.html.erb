<%= link_to "New Conversation", new_conversation_path, class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600" %>
  <% @conversations.each do |conversation| %>
    <%= link_to conversation_path(conversation), class: "block hover:bg-gray-50" do %>
      <%= conversation.title %>
      <%= conversation.messages.count %> messages
      Created <%= time_ago_in_words(conversation.created_at) %> ago
    <% end %>
  <% end %>
